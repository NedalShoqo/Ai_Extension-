{
  "manifest_version": 3,
  "name": "AI Autocomplete",
  "version": "1.0.0",
  "description": "Inline AI completions for text fields on any site",
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:3000/*", "https://*/*", "http://*/*"],
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "AI Autocomplete"
  }
}